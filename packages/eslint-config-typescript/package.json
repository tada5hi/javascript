{
    "name": "@tada5hi/eslint-config-typescript",
    "version": "2.2.0",
    "description": "Shared ESLint flat config for TypeScript projects (deprecated — use @tada5hi/eslint-config)",
    "license": "Apache-2.0",
    "type": "module",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        }
    },
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "files": [
        "dist"
    ],
    "keywords": [
        "eslint",
        "config",
        "eslintconfig",
        "flat-config",
        "typescript"
    ],
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://tada5hi.net"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/tada5hi/javascript.git",
        "directory": "packages/eslint-config-typescript"
    },
    "bugs": {
        "url": "https://github.com/tada5hi/javascript/issues"
    },
    "homepage": "https://github.com/tada5hi/javascript#readme",
    "scripts": {
        "build": "tsc --noEmit -p tsconfig.build.json && tsdown",
        "test": "vitest run -c test/vitest.config.ts"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@tada5hi/eslint-config": "^2.3.0",
        "typescript-eslint": "^8.58.0"
    },
    "peerDependencies": {
        "eslint": ">=10.0.0"
    }
}
