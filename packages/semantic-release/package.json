{
    "name": "@tada5hi/semantic-release",
    "version": "0.4.0",
    "description": "This package provides a sharable semantic-release configuration.",
    "license": "MIT",
    "type": "module",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        }
    },
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "files": [
        "dist"
    ],
    "keywords": [
        "config",
        "configuration",
        "semantic-release",
        "publish",
        "release",
        "workflow"
    ],
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://tada5hi.net"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/tada5hi/javascript.git",
        "directory": "packages/semantic-release"
    },
    "bugs": {
        "url": "https://github.com/tada5hi/javascript/issues"
    },
    "homepage": "https://github.com/tada5hi/javascript#readme",
    "scripts": {
        "build": "tsc --noEmit -p tsconfig.build.json && tsdown"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/git": "^10.0.1"
    },
    "peerDependencies": {
        "semantic-release": ">=23.0.0"
    }
}
