{
    "name": "@tada5hi/prettier-config",
    "version": "1.2.13",
    "description": "Shared Prettier configuration",
    "license": "MIT",
    "type": "module",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs"
        }
    },
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "keywords": [
        "prettier",
        "config",
        "javascript",
        "styleguide"
    ],
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://tada5hi.net"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/tada5hi/javascript.git",
        "directory": "packages/prettier-config"
    },
    "bugs": {
        "url": "https://github.com/tada5hi/javascript/issues"
    },
    "homepage": "https://github.com/tada5hi/javascript#readme",
    "scripts": {
        "build:types": "tsc --emitDeclarationOnly -p tsconfig.build.json",
        "build:js": "rollup -c",
        "build": "rimraf ./dist && cross-env NODE_ENV=production npm run build:js && npm run build:types"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "prettier": "^3.8.1"
    }
}
