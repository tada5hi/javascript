{
    "name": "@tada5hi/eslint-config-vue",
    "version": "1.2.16",
    "description": "Shared ESLint flat config for Vue.js projects (deprecated — use @tada5hi/eslint-config)",
    "license": "MIT",
    "type": "module",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "keywords": [
        "eslint",
        "config",
        "eslintconfig",
        "flat-config",
        "vue",
        "vue.js"
    ],
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://tada5hi.net"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/tada5hi/javascript.git",
        "directory": "packages/eslint-config-vue"
    },
    "bugs": {
        "url": "https://github.com/tada5hi/javascript/issues"
    },
    "homepage": "https://github.com/tada5hi/javascript#readme",
    "scripts": {
        "build": "tsc --noEmit -p tsconfig.build.json && tsdown",
        "test": "vitest run -c test/vitest.config.ts"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@tada5hi/eslint-config": "^1.2.12",
        "eslint-plugin-vue": "^10.0.0"
    },
    "peerDependencies": {
        "eslint": ">=9.0.0"
    }
}
