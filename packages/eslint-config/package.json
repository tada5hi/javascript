{
    "name": "@tada5hi/eslint-config",
    "version": "1.2.12",
    "description": "Shared ESLint flat config for JavaScript projects",
    "license": "MIT",
    "type": "module",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs"
        }
    },
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "keywords": [
        "eslint",
        "config",
        "eslintconfig",
        "flat-config",
        "javascript"
    ],
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://tada5hi.net"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/tada5hi/javascript.git",
        "directory": "packages/eslint-config"
    },
    "bugs": {
        "url": "https://github.com/tada5hi/javascript/issues"
    },
    "homepage": "https://github.com/tada5hi/javascript#readme",
    "scripts": {
        "build:types": "tsc --emitDeclarationOnly -p tsconfig.build.json",
        "build:js": "rollup -c",
        "build": "rimraf ./dist && cross-env NODE_ENV=production npm run build:js && npm run build:types",
        "test": "vitest run -c test/vitest.config.ts"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@eslint/js": "^9.0.0",
        "@stylistic/eslint-plugin": "^4.0.0",
        "eslint-plugin-import-x": "^4.0.0",
        "eslint-plugin-unicorn": "^59.0.0",
        "globals": "^16.0.0"
    },
    "peerDependencies": {
        "eslint": ">=9.0.0"
    }
}
