{
    "name": "@tada5hi/eslint-config",
    "version": "1.2.12",
    "description": "Shared ESLint flat config with optional TypeScript and Vue support",
    "license": "MIT",
    "type": "module",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        }
    },
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "files": [
        "dist"
    ],
    "keywords": [
        "eslint",
        "config",
        "eslintconfig",
        "flat-config",
        "javascript",
        "typescript",
        "vue"
    ],
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://tada5hi.net"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/tada5hi/javascript.git",
        "directory": "packages/eslint-config"
    },
    "bugs": {
        "url": "https://github.com/tada5hi/javascript/issues"
    },
    "homepage": "https://github.com/tada5hi/javascript#readme",
    "scripts": {
        "build": "tsc --noEmit -p tsconfig.build.json && tsdown",
        "test": "vitest run -c test/vitest.config.ts"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@antfu/install-pkg": "^1.1.0",
        "@eslint/js": "^10.0.1",
        "@stylistic/eslint-plugin": "^5.10.0",
        "eslint-plugin-import-x": "^4.0.0",
        "eslint-plugin-unicorn": "^63.0.0",
        "globals": "^17.4.0",
        "smob": "^1.6.1"
    },
    "devDependencies": {
        "eslint-plugin-vue": "^10.8.0",
        "typescript-eslint": "^8.57.1"
    },
    "peerDependencies": {
        "eslint": ">=10.0.0",
        "eslint-plugin-vue": ">=10.0.0",
        "typescript-eslint": ">=8.57.0"
    },
    "peerDependenciesMeta": {
        "typescript-eslint": {
            "optional": true
        },
        "eslint-plugin-vue": {
            "optional": true
        }
    }
}
