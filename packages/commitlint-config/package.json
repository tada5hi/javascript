{
    "name": "@tada5hi/commitlint-config",
    "version": "1.2.7",
    "description": "Shared commitlint configuration",
    "license": "MIT",
    "type": "module",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "keywords": [
        "config",
        "configuration",
        "commits",
        "commitlint",
        "conventional",
        "conventional-commits"
    ],
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://tada5hi.net"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/tada5hi/javascript.git",
        "directory": "packages/commitlint-config"
    },
    "bugs": {
        "url": "https://github.com/tada5hi/javascript/issues"
    },
    "homepage": "https://github.com/tada5hi/javascript#readme",
    "scripts": {
        "build": "tsc --noEmit -p tsconfig.build.json && tsdown"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@commitlint/config-conventional": "^20.4.4"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.4.3"
    },
    "peerDependencies": {
        "@commitlint/cli": "^20.4.3"
    }
}
