{
    "name": "@tada5hi/eslint-config-vue-typescript",
    "version": "1.3.18",
    "description": "Shared ESLint flat config for Vue.js + TypeScript projects",
    "license": "MIT",
    "type": "module",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs"
        }
    },
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "keywords": [
        "eslint",
        "config",
        "eslintconfig",
        "flat-config",
        "vue",
        "vue.js",
        "typescript"
    ],
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://tada5hi.net"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/tada5hi/javascript.git",
        "directory": "packages/eslint-config-vue-typescript"
    },
    "bugs": {
        "url": "https://github.com/tada5hi/javascript/issues"
    },
    "homepage": "https://github.com/tada5hi/javascript#readme",
    "scripts": {
        "build:types": "tsc --emitDeclarationOnly -p tsconfig.build.json",
        "build:js": "rollup -c",
        "build": "rimraf ./dist && cross-env NODE_ENV=production npm run build:js && npm run build:types",
        "test": "vitest run -c test/vitest.config.ts"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@tada5hi/eslint-config-typescript": "^1.2.18",
        "eslint-plugin-vue": "^10.0.0",
        "typescript-eslint": "^8.0.0"
    },
    "peerDependencies": {
        "eslint": ">=9.0.0"
    }
}
